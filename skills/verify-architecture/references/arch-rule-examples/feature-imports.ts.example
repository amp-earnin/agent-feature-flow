#!/usr/bin/env tsx
/**
 * Architecture rule: feature folder import boundaries — EXAMPLE
 *
 * This is a reference implementation for a feature-folder-organized React app
 * (e.g. Vite or Next.js). Copy to your project's scripts/arch/ and adapt:
 *
 *   1. Change FEATURES_ROOT and SRC_ROOT to match your project layout.
 *   2. Change the alias prefix (`#src/`) to your project's TS path alias.
 *   3. Hook into your scripts/verify.sh.
 *
 * What it catches:
 *   Files inside `<features-root>/<A>/` that import from `<features-root>/<B>/`
 *   where A !== B. Cross-feature coupling forces inappropriate refactors and
 *   turns features into a graph instead of leaves. Shared code goes in
 *   `shared/`, `models/`, or `queries/`.
 *
 * CLI:
 *   npx tsx scripts/arch/feature-imports.ts [--format=text|json]
 *
 * Exit codes: 0 = pass, 1 = violations found.
 */
import fg from "fast-glob"
import { readFileSync } from "node:fs"
import { dirname, relative, resolve } from "node:path"

// CUSTOMIZE: these paths describe a monorepo with web app at packages/web/.
// Adjust to your project's layout (e.g. `src/features` for a flat layout).
const REPO_ROOT = resolve(import.meta.dirname, "..", "..")
const FEATURES_ROOT = resolve(REPO_ROOT, "packages/web/src/features")
const SRC_ROOT = resolve(REPO_ROOT, "packages/web/src")

type Violation = {
  file: string
  line: number
  fromFeature: string
  toFeature: string
  importPath: string
}

const format = process.argv.find((a) => a.startsWith("--format="))?.split("=")[1] ?? "text"

function featureOf(absPath: string): string | null {
  const rel = relative(FEATURES_ROOT, absPath)
  if (rel.startsWith("..")) return null
  const [feature] = rel.split("/")
  return feature || null
}

function resolveImport(importingFile: string, importPath: string): string | null {
  // CUSTOMIZE: replace `#src/` with your project's TS path alias prefix.
  if (importPath.startsWith("#src/")) {
    return resolve(SRC_ROOT, importPath.slice("#src/".length))
  }
  if (importPath.startsWith(".")) {
    return resolve(dirname(importingFile), importPath)
  }
  return null
}

const IMPORT_RE = /^\s*(?:import|export)(?:\s+type)?\s+(?:[^"'`]*?from\s+)?["'`]([^"'`]+)["'`]/

const files = await fg("packages/web/src/features/**/*.{ts,tsx}", {
  cwd: REPO_ROOT,
  absolute: true,
  ignore: ["**/*.test.*", "**/*.stories.*", "**/node_modules/**"],
})

const violations: Violation[] = []

for (const file of files) {
  const fromFeature = featureOf(file)
  if (!fromFeature) continue

  const src = readFileSync(file, "utf8")
  const lines = src.split("\n")

  for (let i = 0; i < lines.length; i++) {
    const m = lines[i].match(IMPORT_RE)
    if (!m) continue
    const importPath = m[1]
    const resolved = resolveImport(file, importPath)
    if (!resolved) continue

    const toFeature = featureOf(resolved)
    if (toFeature && toFeature !== fromFeature) {
      violations.push({
        file: relative(REPO_ROOT, file),
        line: i + 1,
        fromFeature,
        toFeature,
        importPath,
      })
    }
  }
}

if (format === "json") {
  console.log(
    JSON.stringify(
      {
        rule: "feature-imports",
        passed: violations.length === 0,
        violations,
      },
      null,
      2,
    ),
  )
} else {
  if (violations.length === 0) {
    console.log("feature-imports: ok (no cross-feature imports)")
  } else {
    console.log(`feature-imports: ${violations.length} violation(s):`)
    for (const v of violations) {
      console.log(`  ${v.file}:${v.line}  ${v.fromFeature} → ${v.toFeature}  "${v.importPath}"`)
    }
    console.log("")
    console.log("Fix: move shared code into your project's shared/ directory, or expose it from")
    console.log("the source feature's public surface and re-evaluate the coupling.")
  }
}

process.exit(violations.length === 0 ? 0 : 1)
